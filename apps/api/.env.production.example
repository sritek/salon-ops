# Production Environment Variables for Railway
# Copy to Railway environment variables (don't commit this file with real values)

# Application
NODE_ENV=production
PORT=3000
API_URL=https://your-api.railway.app
APP_URL=https://your-app.vercel.app

# Database (Neon PostgreSQL)
# Get from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require&connection_limit=10&pool_timeout=30
DIRECT_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis (optional - set ENABLE_REDIS=true when you add Redis)
ENABLE_REDIS=false
# REDIS_URL=redis://default:password@redis.railway.internal:6379

# JWT (IMPORTANT: Generate a secure secret!)
# Generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_MIN_32_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS (optional - add when you need S3)
AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=salon-ops-production
# CDN_URL=https://cdn.your-domain.com

# Monitoring (optional - add Sentry for error tracking)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Logging
LOG_LEVEL=info

# Feature Flags
ENABLE_REDIS=false

# Module Feature Flags (Enable as needed)
ENABLE_INVENTORY=false
ENABLE_MEMBERSHIPS=false
ENABLE_ONLINE_BOOKING=false
ENABLE_MARKETING=false
